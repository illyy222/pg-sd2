//- # SESSIONS LIST PAGE
doctype html
html
  head
    title Study Sessions
    link(rel="stylesheet", href="/style.css")

  body
    h1 📚 Study Sessions

    //- # LOOP THROUGH SESSIONS
    each session in sessions
      .card

        //- # SESSION TITLE
        h2 #{session.title}

        //- # CATEGORY
        p 💖 Category: #{session.category}

        //- # DISPLAY RATING STARS
        if session.rating == 5
          p ⭐⭐⭐⭐⭐
        else if session.rating == 4
          p ⭐⭐⭐⭐
        else if session.rating == 3
          p ⭐⭐⭐
        else if session.rating == 2
          p ⭐⭐
        else
          p ⭐

        //- # LINK TO SESSION DETAILS
        a(href=`/sessions/${session.id}`) 🔍 View Details

    br
    a(href="/") ⬅ Back Home
    




    