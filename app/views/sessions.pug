//- ======================================
//- # SESSIONS PAGE (LIST VIEW)
//- ======================================

doctype html
html
  head
    //- # PAGE TITLE
    title Study Sessions

    //- # LOAD CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    //- # MAIN HEADING
    h1 📚 Study Sessions

    //- # LOOP THROUGH ALL SESSIONS FROM DATABASE
    each session in sessions
      .card
        //- # DISPLAY SESSION TITLE
        h2 #{session.title}

        //- # DISPLAY SESSION CATEGORY
        p 💖 Category: #{session.category}

        //- # NEW FEATURE: LINK SESSION TO USERS (FILTER BY SKILL)
        //- Clicking this takes user to filtered users page
        a(href=`/users?skill=${session.category}`) 👤 Find study partners

        //- # DISPLAY STAR RATING
        if session.rating == 5
          p ⭐⭐⭐⭐⭐
        else if session.rating == 4
          p ⭐⭐⭐⭐
        else if session.rating == 3
          p ⭐⭐⭐
        else if session.rating == 2
          p ⭐⭐
        else
          p ⭐

        //- # LINK TO SINGLE SESSION DETAILS PAGE
        a(href=`/sessions/${session.id}`) 🔍 View Details

    //- # BACK BUTTON TO HOME PAGE
    br
    a(href="/") ⬅ Back Home

    
    




    