//- # SESSIONS PAGE
doctype html
html
  head
    //- # PAGE TITLE
    title Study Sessions

    //- # LINK CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    //- # MAIN HEADING
    h1 📚 Study Sessions

    //- # LOOP THROUGH ALL SESSIONS
    each session in sessions
      .card
        //- # SESSION TITLE
        h2 #{session.title}

        //- # SESSION CATEGORY
        p 💖 Category: #{session.category}

        //- # SHOW CURRENT RATING
        if session.rating == 5
          p ⭐⭐⭐⭐⭐
        else if session.rating == 4
          p ⭐⭐⭐⭐
        else if session.rating == 3
          p ⭐⭐⭐
        else if session.rating == 2
          p ⭐⭐
        else
          p ⭐

        //- # LINK TO SESSION DETAILS PAGE
        a(href=`/sessions/${session.id}`) 🔍 View Details

    //- # BACK BUTTON
    br
    a(href="/") ⬅ Back Home
    




    