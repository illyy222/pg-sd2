//- # SINGLE SESSION DETAIL PAGE
doctype html
html
  head
    //- # PAGE TITLE
    title Session Details

    //- # LINK TO CSS FOR STYLING
    link(rel="stylesheet", href="/style.css")

  body
    //- # CARD CONTAINER (FOR STYLING)
    .card

      //- # SESSION TITLE FROM DATABASE
      h1 📚 #{session.title}

      //- # CATEGORY FROM DATABASE
      p 💖 Category: #{session.category}

      //- # ADVANCED RATING SYSTEM

      if session.rating == 5
        p ⭐⭐⭐⭐⭐
        p 💕 Excellent

      else if session.rating == 4
        p ⭐⭐⭐⭐
        p 💗 Very Good

      else if session.rating == 3
        p ⭐⭐⭐
        p 👍 Good

      else if session.rating == 2
        p ⭐⭐
        p ⚠️ Needs Improvement

      else
        p ⭐
        p ❌ Poor

      br

      //- # BACK BUTTON
      a(href="/sessions") ⬅ Back to Sessions
      

    
    