//- # SINGLE SESSION PAGE
doctype html
html
  head
    title Session Details
    link(rel="stylesheet", href="/style.css")

  body
    .card

      //- # SESSION TITLE
      h1 📚 #{session.title}

      //- # CATEGORY
      p 💖 Category: #{session.category}

      //- # DESCRIPTION (IF EXISTS)
      if session.description
        p #{session.description}

      //- # RATING DISPLAY
      if session.rating == 5
        p ⭐⭐⭐⭐⭐
        p 💕 Excellent
      else if session.rating == 4
        p ⭐⭐⭐⭐
        p 💗 Very Good
      else if session.rating == 3
        p ⭐⭐⭐
        p 👍 Good
      else if session.rating == 2
        p ⭐⭐
        p ⚠️ Needs Improvement
      else
        p ⭐
        p ❌ Poor

      br

      //- # BACK BUTTON
      a(href="/sessions") ⬅ Back to Sessions
      


    
    