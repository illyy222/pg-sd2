//- ======================================
//- # SINGLE SESSION PAGE (DETAIL VIEW)
//- ======================================

doctype html
html
  head
    //- # PAGE TITLE
    title Session Details

    //- # LOAD CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    .card
      //- # DISPLAY SESSION TITLE
      h1 📚 #{session.title}

      //- # DISPLAY CATEGORY
      p 💖 Category: #{session.category}

      //- # FIND USERS BASED ON SKILL
      a(href=`/users?skill=${session.category}`) 👤 Find study partners for this session

      //- # BOOK SESSION BUTTON (NEW FEATURE)
      a(href=`/sessions/${session.id}/book`) 📅 Book this session

      //- # SHOW DESCRIPTION IF AVAILABLE
      if session.description
        p #{session.description}

      //- # DISPLAY RATING WITH TEXT + STARS
      if session.rating == 5
        p ⭐⭐⭐⭐⭐
        p 💕 Excellent
      else if session.rating == 4
        p ⭐⭐⭐⭐
        p 💗 Very Good
      else if session.rating == 3
        p ⭐⭐⭐
        p 👍 Good
      else if session.rating == 2
        p ⭐⭐
        p ⚠️ Needs Improvement
      else
        p ⭐
        p ❌ Poor

      //- # RATING FORM (USER CAN SUBMIT RATING)
      form(method="POST" action=`/sessions/${session.id}/rate`)
        label(for="rating") Rate this session:
        br
        select(name="rating" required)
          option(value="1") 1 Star
          option(value="2") 2 Stars
          option(value="3") 3 Stars
          option(value="4") 4 Stars
          option(value="5") 5 Stars
        br
        br
        button(type="submit") Submit Rating

      //- # BACK BUTTON
      br
      a(href="/sessions") ⬅ Back to Sessions
      


      
      



    
    