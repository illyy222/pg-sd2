//- ======================================
//- # MESSAGES PAGE TEMPLATE
//- ======================================

doctype html
html
  head
    //- # PAGE TITLE
    title Messages

    //- # LINK CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    //- # MAIN TITLE
    h1 💬 Messages

    //- # EXPLANATION TEXT
    p Users can message each other after identifying relevant study support based on user skills.

    //- # ETHICAL NOTE
    p Please use respectful communication when messaging other users.

    //- # VALIDATION NOTE
    p Messages are validated to help prevent spam or misuse.

    //- ======================================
    //- # SEND MESSAGE FORM
    //- ======================================

    .card
      h2 Send a Message

      //- # FORM SENDS MESSAGE DATA TO /messages
      form(method="POST" action="/messages")

        //- # SENDER IS AUTOMATICALLY THE LOGGED-IN USER
        //- # This prevents users pretending to be someone else
        p From: You

        //- # RECEIVER DROPDOWN
        //- # User chooses who they want to message
        p
          label(for="receiver_id") To:
          br
          select(name="receiver_id" required)
            option(value="") -- Select a user --
            each user in users
              option(value=user.id)= user.name

        //- # MESSAGE BOX
        //- # User writes the message here
        p
          label(for="message_text") Message:
          br
          textarea(name="message_text" rows="4" cols="40" required)

        //- # SEND BUTTON
        br
        button(type="submit") Send Message

    //- ======================================
    //- # DISPLAY ALL MESSAGES
    //- ======================================

    //- # IF THERE ARE NO MESSAGES
    if messages.length === 0
      p No messages yet.
    else
      //- # LOOP THROUGH MESSAGES FROM DATABASE
      each message in messages
        .card
          //- # SHOW WHO SENT MESSAGE TO WHO
          p 💌 #{message.sender_name} → #{message.receiver_name}

          //- # SHOW MESSAGE TEXT
          p "#{message.message_text}"

    //- # BACK BUTTON
    br
    a(href="/") ⬅ Back Home

    


    