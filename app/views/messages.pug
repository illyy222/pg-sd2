//- ======================================
//- # MESSAGES PAGE TEMPLATE
//- ======================================

doctype html
html
  head
    //- # PAGE TITLE (browser tab)
    title Messages

    //- # LINK CSS STYLING
    link(rel="stylesheet", href="/style.css")

  body
    //- ======================================
    //- # PAGE HEADER
    //- ======================================

    //- # MAIN TITLE
    h1 💬 Messages

    //- # EXPLANATION OF FEATURE
    p Users can message each other after identifying relevant study support based on user skills.

    //- # ETHICAL NOTE (GOOD FOR MARKS)
    p Please use respectful communication when messaging other users.

    //- # VALIDATION NOTE (SHOWS SECURITY AWARENESS)
    p Messages are validated to help prevent spam or misuse.

    //- ======================================
    //- # SEND MESSAGE FORM
    //- ======================================

    .card
      h2 Send a Message

      //- # FORM SENDS DATA TO BACKEND ROUTE /messages
      form(method="POST" action="/messages")

        //- # SENDER DROPDOWN (WHO IS SENDING)
        p
          label(for="sender_id") From:
          br
          select(name="sender_id" required)
            each user in users
              option(value=user.id)= user.name

        //- # RECEIVER DROPDOWN (WHO RECEIVES MESSAGE)
        p
          label(for="receiver_id") To:
          br
          select(name="receiver_id" required)
            //- # DEFAULT OPTION (FORCES USER TO CHOOSE)
            option(value="") -- Select a user --
            each user in users
              option(value=user.id)= user.name

        //- # MESSAGE INPUT BOX
        p
          label(for="message_text") Message:
          br
          textarea(name="message_text" rows="4" cols="40" required)

        //- # SUBMIT BUTTON (SEND MESSAGE)
        br
        button(type="submit") Send Message

    //- ======================================
    //- # DISPLAY MESSAGES
    //- ======================================

    //- # CHECK IF ANY MESSAGES EXIST
    if messages.length === 0
      //- # SHOW MESSAGE IF EMPTY
      p No messages yet.
    else
      //- # LOOP THROUGH ALL MESSAGES FROM DATABASE
      each message in messages
        .card
          //- # SHOW SENDER AND RECEIVER
          p 💌 #{message.sender_name} → #{message.receiver_name}

          //- # SHOW MESSAGE CONTENT
          p "#{message.message_text}"

    //- ======================================
    //- # NAVIGATION
    //- ======================================

    //- # BACK TO HOME PAGE
    br
    a(href="/") ⬅ Back Home

    
    