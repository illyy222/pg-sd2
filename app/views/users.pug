//- # USERS LIST PAGE
doctype html
html
  head
    title Users
    link(rel="stylesheet", href="/style.css")

  body
    h1 👩‍🎓 Users

    //- # LOOP THROUGH USERS
    each user in users
      .card
        //- # USER NAME
        p #{user.name}

        //- # LINK TO PROFILE PAGE
        a(href=`/users/${user.id}`) View Profile

    br
    a(href="/") ⬅ Back Home

    
