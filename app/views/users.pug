//- # USERS PAGE TEMPLATE
doctype html
html
  head
    //- # PAGE TITLE (shows in browser tab)
    title Study Partners

    //- # LINK TO CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    //- # MAIN HEADING
    h1 👩‍🎓 Study Partners

    //- # PRIVACY MESSAGE
    p This page only shows basic user information for study support purposes.

    //- # SEARCH FORM (filters users by skill)
    form(action="/users" method="GET")
      input(type="text" name="skill" placeholder="Search by skill e.g. Java")
      button(type="submit") Search

    //- # CHECK IF ANY USERS FOUND
    if users.length === 0
      //- # SHOW MESSAGE IF NO RESULTS
      p ❌ No users found for this skill.
    else
      //- # LOOP THROUGH USERS FROM DATABASE
      each user in users
        .card
          //- # DISPLAY USER NAME
          p #{user.name}

          //- # DISPLAY USER SKILLS (FROM DATABASE NOW)
          p 🧠 Good at: #{user.skills}

          //- # LINK TO INDIVIDUAL PROFILE PAGE
          a(href=`/users/${user.id}`) View Profile

    //- # BACK BUTTON TO HOME PAGE
    br
    a(href="/") ⬅ Back Home

    
    