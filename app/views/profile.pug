//- # PROFILE PAGE
doctype html
html
  head
    //- # PAGE TITLE
    title User Profile

    //- # LINK CSS FILE
    link(rel="stylesheet", href="/style.css")

  body
    .card
      //- # SHOW USER NAME
      h1 👤 #{user.name}

      //- # SHOW EMAIL IF IT EXISTS
      if user.email
        p 📧 #{user.email}

      //- # SHOW USER SKILLS
      p 🧠 Good at: #{user.skills}

      //- # ETHICAL PRIVACY NOTE
      p Only relevant academic information is shown to protect user privacy.

      //- # EXPLANATION OF PURPOSE
      p This helps other users understand what kind of study support this student can provide.

      //- # BACK BUTTON
      br
      a(href="/users") ⬅ Back to Study Partners
      



    